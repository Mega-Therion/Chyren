[Unit]
Description=chyren Bridge (Canonical Sovereign)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=mega
Group=mega
WorkingDirectory=/home/mega/Chyren
EnvironmentFile=-/home/mega/Chyren/state/vault/one-true.env
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/mega/Chyren/packages/bridge/.venv/bin/python -m uvicorn api:app --host 127.0.0.1 --port 8000
StandardOutput=journal
StandardError=journal
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
