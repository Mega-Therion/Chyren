#!/usr/bin/env node
const { execSync } = require('child_process');
const args = process.argv.slice(2).join(' ');
try {
    const result = execSync(`npx @google/gemini-cli ${args}`, { stdio: 'pipe' });
    process.stdout.write(result);
} catch (e) {
    if (e.stderr) process.stderr.write(e.stderr);
    process.exit(1);
}
