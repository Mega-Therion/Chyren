# Use the existing build for the API as a base, then install the new gateway binary
FROM rustlang/rust:nightly-slim-bookworm AS builder
WORKDIR /usr/src/app
COPY . .
RUN cargo build --package omega-telegram-gateway --release

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y libssl-dev ca-certificates && rm -rf /var/lib/apt/lists/*
COPY --from=builder /usr/src/app/target/release/omega-telegram-gateway /usr/local/bin/gateway
CMD ["gateway"]
