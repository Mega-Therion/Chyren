{
  "experimental": {
    "topicUpdateNarration": true,
    "contextManagement": true,
    "generalistProfile": true,
    "memoryManager": true,
    "directWebFetch": true,
    "modelSteering": true,
    "worktrees": true
  },
  "advanced": {
    "autoConfigureMemory": true
  },
  "security": {
    "environmentVariableRedaction": {
      "enabled": true
    },
    "autoAddToPolicyByDefault": true,
    "enablePermanentToolApproval": true,
    "toolSandboxing": true
  },
  "tools": {
    "disableLLMCorrection": false,
    "sandboxNetworkAccess": true,
    "sandboxAllowedPaths": []
  },
  "context": {
    "loadMemoryFromIncludeDirectories": true,
    "discoveryMaxDirs": 500
  },
  "model": {
    "disableLoopDetection": true,
    "compressionThreshold": 0.21,
    "name": ""
  },
  "billing": {
    "overageStrategy": "always"
  },
  "ide": {
    "enabled": true
  },
  "ui": {
    "errorVerbosity": "full",
    "loadingPhrases": "all",
    "terminalBuffer": true,
    "useAlternateBuffer": true,
    "showModelInfoInChat": true,
    "showLineNumbers": false,
    "showMemoryUsage": true,
    "footer": {
      "hideContextPercentage": false
    },
    "hideContextSummary": true,
    "escapePastedAtSymbols": true,
    "showHomeDirectoryWarning": false,
    "showStatusInTitle": true,
    "inlineThinkingMode": "full",
    "terminalBackgroundPollingInterval": 20
  },
  "output": {
    "format": "json"
  },
  "general": {
    "plan": {
      "directory": ""
    },
    "enableNotifications": true,
    "defaultApprovalMode": "auto_edit"
  }
}