{
  "name": "clickup_new_checklist",
  "description": "Add a checklist to a task",
  "arguments": {
    "type": "object",
    "properties": {
      "instructions": {
        "type": "string"
      },
      "output_hint": {
        "type": "string",
        "description": "REQUIRED. Natural language description of what data you want from the results. Example: 'just the title and created date' or 'only items with status active, showing id and name'. A filter will be automatically generated to extract this data."
      },
      "name": {
        "type": [
          "string",
          "null"
        ],
        "description": "Checklist Name"
      },
      "items": {
        "type": "array",
        "items": {
          "anyOf": [
            {
              "not": {}
            },
            {
              "type": [
                "string",
                "null"
              ]
            }
          ],
          "description": "Checklist Item"
        }
      },
      "team_id": {
        "type": [
          "string",
          "null"
        ],
        "description": "Workspace"
      }
    },
    "required": [
      "instructions"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}