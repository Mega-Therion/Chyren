{
  "name": "slack_edit_canvas",
  "description": "Edits a Canvas.",
  "arguments": {
    "type": "object",
    "properties": {
      "instructions": {
        "type": "string"
      },
      "output_hint": {
        "type": "string",
        "description": "REQUIRED. Natural language description of what data you want from the results. Example: 'just the title and created date' or 'only items with status active, showing id and name'. A filter will be automatically generated to extract this data."
      },
      "content": {
        "type": [
          "string",
          "null"
        ],
        "description": "Content"
      },
      "canvas_id": {
        "type": [
          "string",
          "null"
        ],
        "description": "Canvas ID"
      },
      "operation": {
        "type": [
          "string",
          "null"
        ],
        "description": "Operation"
      }
    },
    "required": [
      "instructions"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}