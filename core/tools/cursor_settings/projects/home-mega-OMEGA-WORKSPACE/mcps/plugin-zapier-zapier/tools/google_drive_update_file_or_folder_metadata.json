{
  "name": "google_drive_update_file_or_folder_metadata",
  "description": "Update file or folder metadata including name, description, starred status, folder color, and custom properties.",
  "arguments": {
    "type": "object",
    "properties": {
      "instructions": {
        "type": "string"
      },
      "output_hint": {
        "type": "string",
        "description": "REQUIRED. Natural language description of what data you want from the results. Example: 'just the title and created date' or 'only items with status active, showing id and name'. A filter will be automatically generated to extract this data."
      },
      "name": {
        "type": [
          "string",
          "null"
        ],
        "description": "Name"
      },
      "drive": {
        "type": [
          "string",
          "null"
        ],
        "description": "Drive"
      },
      "folder": {
        "type": [
          "string",
          "null"
        ],
        "description": "Folder"
      },
      "file_id": {
        "type": [
          "string",
          "null"
        ],
        "description": "File"
      },
      "starred": {
        "type": [
          "string",
          "null"
        ],
        "description": "Starred"
      },
      "properties": {
        "type": [
          "string",
          "null"
        ],
        "description": "Custom Properties"
      },
      "description": {
        "type": [
          "string",
          "null"
        ],
        "description": "Description"
      },
      "folder_color_rgb": {
        "type": [
          "string",
          "null"
        ],
        "description": "Folder Color (RGB)"
      }
    },
    "required": [
      "instructions"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}