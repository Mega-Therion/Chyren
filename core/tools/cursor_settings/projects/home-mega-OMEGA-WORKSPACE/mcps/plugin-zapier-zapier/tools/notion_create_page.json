{
  "name": "notion_create_page",
  "description": "Creates a Page inside a parent page",
  "arguments": {
    "type": "object",
    "properties": {
      "instructions": {
        "type": "string"
      },
      "output_hint": {
        "type": "string",
        "description": "REQUIRED. Natural language description of what data you want from the results. Example: 'just the title and created date' or 'only items with status active, showing id and name'. A filter will be automatically generated to extract this data."
      },
      "icon": {
        "type": [
          "string",
          "null"
        ],
        "description": "Icon"
      },
      "cover": {
        "type": [
          "string",
          "null"
        ],
        "description": "Cover"
      },
      "title": {
        "type": [
          "string",
          "null"
        ],
        "description": "Title"
      },
      "content": {
        "type": [
          "string",
          "null"
        ],
        "description": "Content"
      },
      "parent_page": {
        "type": [
          "string",
          "null"
        ],
        "description": "Parent Page"
      }
    },
    "required": [
      "instructions"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}