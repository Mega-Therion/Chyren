{
  "name": "notion_add_block_to_page",
  "description": "Adds a new content block to an existing Notion page. Supports various block types including paragraphs, headings, lists, to-dos, callouts, code blocks, and more.",
  "arguments": {
    "type": "object",
    "properties": {
      "instructions": {
        "type": "string"
      },
      "output_hint": {
        "type": "string",
        "description": "REQUIRED. Natural language description of what data you want from the results. Example: 'just the title and created date' or 'only items with status active, showing id and name'. A filter will be automatically generated to extract this data."
      },
      "checked": {
        "type": [
          "string",
          "null"
        ],
        "description": "Checked"
      },
      "content": {
        "type": [
          "string",
          "null"
        ],
        "description": "Content"
      },
      "page_id": {
        "type": [
          "string",
          "null"
        ],
        "description": "Page"
      },
      "language": {
        "type": [
          "string",
          "null"
        ],
        "description": "Programming Language"
      },
      "block_type": {
        "type": [
          "string",
          "null"
        ],
        "description": "Block Type"
      },
      "icon_emoji": {
        "type": [
          "string",
          "null"
        ],
        "description": "Icon (Emoji)"
      }
    },
    "required": [
      "instructions"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}