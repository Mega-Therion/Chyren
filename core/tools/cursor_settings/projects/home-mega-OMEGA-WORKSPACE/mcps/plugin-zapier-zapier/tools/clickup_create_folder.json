{
  "name": "clickup_create_folder",
  "description": "Creates a new folder",
  "arguments": {
    "type": "object",
    "properties": {
      "instructions": {
        "type": "string"
      },
      "output_hint": {
        "type": "string",
        "description": "REQUIRED. Natural language description of what data you want from the results. Example: 'just the title and created date' or 'only items with status active, showing id and name'. A filter will be automatically generated to extract this data."
      },
      "name": {
        "type": [
          "string",
          "null"
        ],
        "description": "Folder Name"
      },
      "team_id": {
        "type": [
          "string",
          "null"
        ],
        "description": "Workspace"
      }
    },
    "required": [
      "instructions"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}