{
  "name": "google_sheets_find_worksheet",
  "description": "Finds a worksheet by title.",
  "arguments": {
    "type": "object",
    "properties": {
      "instructions": {
        "type": "string"
      },
      "output_hint": {
        "type": "string",
        "description": "REQUIRED. Natural language description of what data you want from the results. Example: 'just the title and created date' or 'only items with status active, showing id and name'. A filter will be automatically generated to extract this data."
      },
      "drive": {
        "type": [
          "string",
          "null"
        ],
        "description": "Drive"
      },
      "title": {
        "type": [
          "string",
          "null"
        ],
        "description": "Title"
      },
      "spreadsheet": {
        "type": [
          "string",
          "null"
        ],
        "description": "Spreadsheet"
      }
    },
    "required": [
      "instructions"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}