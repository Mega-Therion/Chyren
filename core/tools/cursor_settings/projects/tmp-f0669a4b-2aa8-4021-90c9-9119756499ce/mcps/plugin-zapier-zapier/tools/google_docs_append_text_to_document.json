{
  "name": "google_docs_append_text_to_document",
  "description": "Appends text to an existing document.",
  "arguments": {
    "type": "object",
    "properties": {
      "instructions": {
        "type": "string"
      },
      "output_hint": {
        "type": "string",
        "description": "REQUIRED. Natural language description of what data you want from the results. Example: 'just the title and created date' or 'only items with status active, showing id and name'. A filter will be automatically generated to extract this data."
      },
      "file": {
        "type": [
          "string",
          "null"
        ],
        "description": "Document Name"
      },
      "text": {
        "type": [
          "string",
          "null"
        ],
        "description": "Text to Append"
      },
      "drive": {
        "type": [
          "string",
          "null"
        ],
        "description": "Drive"
      },
      "folder": {
        "type": [
          "string",
          "null"
        ],
        "description": "Folder"
      },
      "newline": {
        "type": [
          "string",
          "null"
        ],
        "description": "Append Text on New Line?"
      }
    },
    "required": [
      "instructions"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}