{
  "name": "hubspot_upload_file",
  "description": "Uploads a file to HubSpot File Manager.",
  "arguments": {
    "type": "object",
    "properties": {
      "instructions": {
        "type": "string"
      },
      "output_hint": {
        "type": "string",
        "description": "REQUIRED. Natural language description of what data you want from the results. Example: 'just the title and created date' or 'only items with status active, showing id and name'. A filter will be automatically generated to extract this data."
      },
      "file": {
        "type": [
          "string",
          "null"
        ],
        "description": "File"
      },
      "access": {
        "type": [
          "string",
          "null"
        ],
        "description": "Access level"
      },
      "filename": {
        "type": [
          "string",
          "null"
        ],
        "description": "Filename"
      },
      "folderId": {
        "type": [
          "string",
          "null"
        ],
        "description": "Folder"
      }
    },
    "required": [
      "instructions"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}