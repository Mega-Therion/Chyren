{
  "name": "google_drive_find_a_file",
  "description": "Search for a specific file by name.",
  "arguments": {
    "type": "object",
    "properties": {
      "instructions": {
        "type": "string"
      },
      "output_hint": {
        "type": "string",
        "description": "REQUIRED. Natural language description of what data you want from the results. Example: 'just the title and created date' or 'only items with status active, showing id and name'. A filter will be automatically generated to extract this data."
      },
      "drive": {
        "type": [
          "string",
          "null"
        ],
        "description": "Drive"
      },
      "title": {
        "type": [
          "string",
          "null"
        ],
        "description": "Filename"
      },
      "folder": {
        "type": [
          "string",
          "null"
        ],
        "description": "Folder"
      },
      "file_types": {
        "type": "array",
        "items": {
          "anyOf": [
            {
              "not": {}
            },
            {
              "type": [
                "string",
                "null"
              ]
            }
          ],
          "description": "File Types"
        }
      },
      "search_type": {
        "type": [
          "string",
          "null"
        ],
        "description": "Search Type"
      }
    },
    "required": [
      "instructions"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}