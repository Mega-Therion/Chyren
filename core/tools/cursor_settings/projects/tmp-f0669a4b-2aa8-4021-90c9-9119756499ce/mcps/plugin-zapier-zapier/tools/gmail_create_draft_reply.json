      "instructions": {
        "type": "string"
      },
      "output_hint": {
        "type": "string",
        "description": "REQUIRED. Natural language description of what data you want from the results. Example: 'just the title and created date' or 'only items with status active, showing id and name'. A filter will be automatically generated to extract this data."
      },
      "cc": {
        "type": "array",
        "items": {
          "anyOf": [
            {
              "not": {}
            },
            {
              "type": [
                "string",
                "null"
              ]
            }
          ],
          "description": "Cc"
        }
      },
      "to": {
        "type": "array",
        "items": {
          "anyOf": [
            {
              "not": {}
            },
            {
              "type": [
                "string",
                "null"
              ]
            }
          ],
          "description": "To"
        }
      },
      "bcc": {
        "type": "array",
        "items": {
          "anyOf": [
            {
              "not": {}
            },
            {
              "type": [
                "string",
                "null"
              ]
            }
          ],
          "description": "Bcc"
        }
      },
      "body": {
        "type": [
          "string",
          "null"
        ],
        "description": "Body"
      },
      "file": {
        "type": "array",
        "items": {
          "anyOf": [
            {
              "not": {}
            },
            {
              "type": [
                "string",
                "null"
              ]
            }
          ],
