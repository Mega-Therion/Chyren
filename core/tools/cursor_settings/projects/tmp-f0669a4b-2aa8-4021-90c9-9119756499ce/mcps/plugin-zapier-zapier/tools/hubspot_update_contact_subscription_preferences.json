{
  "name": "hubspot_update_contact_subscription_preferences",
  "description": "Adds a contact to one or more subscription types in HubSpot.",
  "arguments": {
    "type": "object",
    "properties": {
      "instructions": {
        "type": "string"
      },
      "output_hint": {
        "type": "string",
        "description": "REQUIRED. Natural language description of what data you want from the results. Example: 'just the title and created date' or 'only items with status active, showing id and name'. A filter will be automatically generated to extract this data."
      },
      "email": {
        "type": [
          "string",
          "null"
        ],
        "description": "Contact Email"
      },
      "subscription_type_ids": {
        "type": "array",
        "items": {
          "anyOf": [
            {
              "not": {}
            },
            {
              "type": [
                "string",
                "null"
              ]
            }
          ],
          "description": "Subscription Types"
        }
      },
      "legal_basis_explanation": {
        "type": [
          "string",
          "null"
        ],
        "description": "Legal Basis Explanation"
      }
    },
    "required": [
      "instructions"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}