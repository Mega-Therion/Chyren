#!/usr/bin/env python3
import sys
import os
import logging
import shutil
import signal
import subprocess
from typing import List, Optional

# THE BRAIN STEM: Unified Official Chyren CLI
#
# Routing map (post-migration):
#   thought / sense / verify / identity  →  Medulla (Rust sovereign pipeline)
#   action  / flex  / shard / ingest / memory  →  Medulla
#   status / reset   →  Medulla subcommands
#   live             →  Medulla API server + Next.js frontend
#   telegram         →  Medulla Telegram gateway binary
#   dream            →  Python maintenance scripts (identity synthesis + catalog)
#
# Python cortex/main.py is no longer invoked at runtime.

REPO_DIR = os.path.dirname(os.path.abspath(__file__))
CORTEX_DIR = os.path.join(REPO_DIR, "cortex")
MEDULLA_DIR = os.path.join(REPO_DIR, "medulla")


def _load_env() -> None:
    """Load secrets from well-known env files (highest priority first)."""
    candidates = [
        os.path.expanduser("~/.omega_keys.env"),
        os.path.expanduser("~/.omega/one-true.env"),
        os.path.expanduser("~/OMEGA_WORKSPACE/VAULT/one-true.env"),
    ]
    for path in candidates:
        if os.path.isfile(path):
            try:
                with open(path) as f:
                    for line in f:
                        line = line.strip()
                        if not line or line.startswith("#") or "=" not in line:
                            continue
                        key, _, val = line.partition("=")
                        key = key.strip()
                        val = val.strip().strip('"').strip("'")
                        if key and key not in os.environ:
                            os.environ[key] = val
            except OSError:
                pass

LOG = logging.getLogger("chyren")


def _configure_logging() -> None:
    level = os.getenv("CHYREN_LOG_LEVEL", "INFO").upper()
    logging.basicConfig(
        level=getattr(logging, level, logging.INFO),
        format="%(levelname)s %(message)s",
    )


def _require_tool(tool: str) -> None:
    if shutil.which(tool) is None:
        raise SystemExit(f"[chyren] required tool not found on PATH: {tool}")


def _run(cmd: List[str], *, cwd: Optional[str] = None) -> subprocess.CompletedProcess:
    LOG.debug("exec: %s (cwd=%s)", " ".join(cmd), cwd or os.getcwd())
    return subprocess.run(cmd, cwd=cwd)


def _medulla_bin(name: str = "chyren") -> str:
    if name == "chyren":
        env_key = "CHYREN_MEDULLA_BIN"
        default = os.path.join(MEDULLA_DIR, "target", "release", "chyren")
        pkg = "omega-cli"
    else:
        env_key = f"CHYREN_{name.upper()}_BIN"
        default = os.path.join(MEDULLA_DIR, "target", "release", name)
        pkg = f"omega-{name.split('-')[0]}"

    path = os.getenv(env_key, default)
    if not os.path.exists(path):
        # Fallback to root target folder (for workspace builds)
        root_target = os.path.join(REPO_DIR, "target", "release", name)
        if os.path.exists(root_target):
            path = root_target
            
    if not os.path.exists(path):
        if os.getenv("CHYREN_AUTO_BUILD", "").lower() not in ("1", "true", "yes"):
            raise SystemExit(
                f"[chyren] Medulla binary '{name}' not found at {path}.\n"
                f"  Build it: cd medulla && cargo build --release -p {pkg}\n"
                "  Or set CHYREN_AUTO_BUILD=1."
            )
        _require_tool("cargo")
        LOG.warning("Building Medulla binary '%s' (release)...", name)
        res = _run(
            ["cargo", "build", "--release", "-p", pkg, "--bin", name],
            cwd=MEDULLA_DIR,
        )
        if res.returncode != 0 or not os.path.exists(path):
            raise SystemExit(f"[chyren] cargo build failed for '{name}'.")
    return path


def run_medulla(args: List[str], bin_name: str = "chyren") -> subprocess.CompletedProcess:
    return _run([_medulla_bin(bin_name)] + args)


def main() -> None:
    _load_env()
    _configure_logging()

    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help"):
        print(
            "Usage: chyren <command> [args]\n\n"
            "Commands:\n"
            "  thought / sense / verify / identity  — Sovereign reasoning pipeline (Medulla)\n"
            "  action  / flex / shard / ingest / memory  — Execution pipeline (Medulla)\n"
            "  status    — System status\n"
            "  reset     — Reset ledger (requires CHYREN_ALLOW_RESET=1)\n"
            "  live      — Start web + API server\n"
            "  telegram  — Start Telegram gateway\n"
            "  dream     — Maintenance: identity synthesis + catalog indexing\n"
            "  --version — Print version\n"
        )
        sys.exit(0)

    if sys.argv[1] == "--version":
        res = run_medulla(["--version"])
        sys.exit(res.returncode)

    cmd_type = sys.argv[1]
    remainder = sys.argv[2:]

    # ── Sovereign pipeline (all reasoning AND execution routes to Medulla) ──────
    if cmd_type in (
        "thought", "sense", "verify", "identity",   # reasoning commands
        "action", "flex", "shard", "ingest", "memory",  # execution commands
    ):
        res = run_medulla(remainder)
        sys.exit(res.returncode)

    # ── Explicit subcommands ──────────────────────────────────────────────────
    elif cmd_type == "status":
        print("--- Unified Brain State ---")
        print("Hemisphere R (Medulla): HIGH-SPEED SOVEREIGN RUNTIME — ACTIVE")
        print("Yettragrammaton: R.W.Ϝ.Y.")
        print("Bridge (Stem): ACTIVE")
        res = run_medulla(["status"] + remainder)
        sys.exit(res.returncode)

    elif cmd_type == "reset":
        res = run_medulla(["reset"] + remainder)
        sys.exit(res.returncode)

    elif cmd_type == "telegram":
        LOG.info("Starting Telegram Gateway (chyren-telegram)...")
        sys.exit(run_medulla(remainder, bin_name="chyren-telegram").returncode)

    elif cmd_type == "live":
        LOG.info("Bootstrapping Live Hub (Next.js + Medulla API)...")
        _require_tool("npm")
        binary = _medulla_bin()
        medulla_proc: Optional[subprocess.Popen] = None
        try:
            medulla_proc = subprocess.Popen([binary, "server"])
            res = _run(["npm", "run", "dev"], cwd=os.path.join(REPO_DIR, "web"))
            sys.exit(res.returncode)
        finally:
            if medulla_proc and medulla_proc.poll() is None:
                medulla_proc.send_signal(signal.SIGINT)
                try:
                    medulla_proc.wait(timeout=5)
                except subprocess.TimeoutExpired:
                    medulla_proc.kill()

    elif cmd_type == "dream":
        # Maintenance mode: identity synthesis + catalog indexing.
        # These are Python data-pipeline scripts, not cortex runtime.
        LOG.info("Entering Dream State (Autonomous Maintenance)...")
        r1 = _run([
            sys.executable,
            os.path.join(CORTEX_DIR, "chyren_py", "identity_synthesis.py"),
        ])
        r2 = _run([
            sys.executable,
            os.path.join(CORTEX_DIR, "ops", "scripts", "catalog_registrar.py"),
        ])
        if r1.returncode != 0 or r2.returncode != 0:
            raise SystemExit("[chyren] dream cycle failed.")
        LOG.info("Dream cycle complete. Memory indexed.")
        sys.exit(0)

    else:
        # Default: pass everything as task args to the Medulla binary.
        res = run_medulla(sys.argv[1:])
        sys.exit(res.returncode)


if __name__ == "__main__":
    main()
