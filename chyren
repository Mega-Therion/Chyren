def cmd_live(remainder: list[str]) -> int:
    LOG.info("Bootstrapping Live Hub (Next.js + Medulla API)...")
    require_tool("npm")
    binary = medulla_bin()

    medulla_proc: Optional[subprocess.Popen] = None
    web_proc: Optional[subprocess.Popen] = None
    received_signal = {"sig": None}

    def _propagate(sig: int, _frame: object) -> None:
        received_signal["sig"] = sig
        LOG.info("live: received signal %s — shutting down children", sig)
        for proc in (web_proc, medulla_proc):
            if proc and proc.poll() is None:
                try:
                    proc.send_signal(signal.SIGTERM)
                except ProcessLookupError:
                    pass

    prev_int = signal.signal(signal.SIGINT, _propagate)
    prev_term = signal.signal(signal.SIGTERM, _propagate)

    emit_event("live.start")
    try:
        medulla_proc = subprocess.Popen([str(binary), "server", *remainder])
        web_proc = subprocess.Popen(
            ["npm", "run", "dev"],
            cwd=str(REPO_DIR / "web"),
        )
        # Wait for whichever exits first.
        while True:
            time.sleep(0.5)
            if medulla_proc.poll() is not None:
                LOG.warning("live: Medulla exited (code=%s)", medulla_proc.returncode)
                break
            if web_proc.poll() is not None:
                LOG.warning("live: web exited (code=%s)", web_proc.returncode)
                break
            if received_signal["sig"] is not None:
                break
        rc = medulla_proc.returncode if medulla_proc.returncode is not None else (web_proc.returncode or 0)
        return rc
    finally:
        signal.signal(signal.SIGINT, prev_int)
        signal.signal(signal.SIGTERM, prev_term)
        for proc in (web_proc, medulla_proc):
            if proc and proc.poll() is None:
                try:
                    proc.send_signal(signal.SIGTERM)
                    proc.wait(timeout=5)
                except subprocess.TimeoutExpired:
                    proc.kill()
                except ProcessLookupError:
                    pass
        emit_event("live.stop", signal=received_signal["sig"])


def cmd_dream(args: argparse.Namespace) -> int:
    LOG.info("Entering Dream State (Autonomous Maintenance)...")
    emit_event("dream.start")
    
    if getattr(args, 'ingest_hf', False) or getattr(args, 'queue', False) or getattr(args, 'enqueue', None):
        script_dir = CORTEX_DIR / "ops" / "scripts"
        py = get_python_exe()
        if getattr(args, 'queue', False):
            cmd = [py, str(script_dir / "hf_queue_manager.py"), "--status"]
        elif getattr(args, 'enqueue', None):
            cmd = [py, str(script_dir / "hf_queue_manager.py"), "--prioritize", args.enqueue]
        else:
            # Default behavior for --ingest-hf: replenish and run one cycle
            run_subprocess([py, str(script_dir / "hf_queue_manager.py"), "--replenish"])
            cmd = [py, str(script_dir / "hf_pipeline_worker.py")]
        
        # Ensure we have OMEGA_CATALOG_DB_URL
        env = os.environ.copy()
        if "OMEGA_CATALOG_DB_URL" not in env:
            env["OMEGA_CATALOG_DB_URL"] = env.get("NEON_URL", "") # fallback if needed
            
        return subprocess.run(cmd, cwd=REPO_DIR, env=env).returncode

    with exclusive_lock(DREAM_LOCK):
        py = get_python_exe()
        identity = CORTEX_DIR / "chyren_py" / "identity_synthesis.py"
        catalog = CORTEX_DIR / "ops" / "scripts" / "catalog_registrar.py"
        for script in (identity, catalog):
            if not script.is_file():
                emit_event("dream.fail", missing=str(script))
                # Fallback to current dir if needed
                if not script.exists():
                    LOG.warning("Script not found at %s, attempting relative search", script)
                    # Implementation detail: just fail if really missing
        
        limit = "100" if getattr(args, 'micro', False) else "5000"
        r1 = run_subprocess([py, str(identity), "--limit", limit])
        
        # Only run full catalog on non-micro dreams
        r2_code = 0
        if not getattr(args, 'micro', False):
            r2 = run_subprocess([py, str(catalog)])
            r2_code = r2.returncode
            
        if r1.returncode != 0 or r2_code != 0:
            emit_event("dream.fail", identity=r1.returncode, catalog=r2_code)
            raise SystemExit("[chyren] dream cycle failed.")
    LOG.info("Dream cycle complete. Memory indexed.")
    emit_event("dream.complete")
    return 0


# ─── Argparse wiring ──────────────────────────────────────────────────────────

def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="chyren",
        description="Chyren brain stem — dispatches to the Medulla sovereign runtime.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "Environment:\n"
            "  CHYREN_LOG_LEVEL          DEBUG/INFO/WARN/ERROR (default: INFO)\n"
            "  CHYREN_LOG_FORMAT         text/json (default: text)\n"
            "  CHYREN_TELEMETRY_DISABLE  Set to 1 to skip state/cli_events.jsonl writes\n"
            "  CHYREN_AUTO_BUILD         Set to 1 to auto cargo-build missing binaries\n"
            "  CHYREN_MEDULLA_BIN        Override path to chyren Medulla binary\n"
            "  CHYREN_ALLOW_RESET        Set to 1 to permit reset without --yes\n"
        ),
    )
    parser.add_argument("--version", action="version", version=f"chyren {VERSION}")
    parser.add_argument(
        "--log-level",
        default=os.getenv("CHYREN_LOG_LEVEL", "INFO"),
        help="DEBUG/INFO/WARN/ERROR (default INFO; or CHYREN_LOG_LEVEL).",
    )
    parser.add_argument(
        "--log-format",
        default=os.getenv("CHYREN_LOG_FORMAT", "text"),
        choices=("text", "json"),
        help="Log line format (default text; or CHYREN_LOG_FORMAT).",
    )

    sub = parser.add_subparsers(dest="command", metavar="<command>")

    def _add_passthrough(name: str, help_text: str) -> None:
        p = sub.add_parser(name, help=help_text, add_help=False)
        p.add_argument("args", nargs=argparse.REMAINDER, help="Forwarded to Medulla")

    for n in sorted(MEDULLA_REASONING_CMDS):
        _add_passthrough(n, f"Sovereign reasoning: {n}")
    for n in sorted(MEDULLA_EXECUTION_CMDS):
        _add_passthrough(n, f"Execution pipeline: {n}")

    p_status = sub.add_parser("status", help="Print unified brain status.")
    p_status.add_argument("--geometric", action="store_true", help="Include Holonomy Pulse metrics (Ω·χ).")
    p_status.add_argument("args", nargs=argparse.REMAINDER)

    p_reset = sub.add_parser("reset", help="Reset the Medulla ledger (destructive).")
    p_reset.add_argument("--yes", action="store_true", help="Skip the confirmation prompt.")
    p_reset.add_argument("args", nargs=argparse.REMAINDER)

    p_telegram = sub.add_parser("telegram", help="Run the Medulla Telegram gateway binary.")
    p_telegram.add_argument("args", nargs=argparse.REMAINDER)

    p_live = sub.add_parser("live", help="Boot Medulla API + Next.js dev server.")
    p_live.add_argument("args", nargs=argparse.REMAINDER)

    p_dream = sub.add_parser("dream", help="Maintenance mode: identity synthesis + catalog indexing.")
    p_dream.add_argument("--micro", action="store_true", help="Run a high-speed 'micro' synthesis cycle (recency bias).")
    p_dream.add_argument("--ingest-hf", action="store_true", help="Run the autonomous HF ingestion pipeline.")
    p_dream.add_argument("--queue", action="store_true", help="Show current HF ingestion queue status.")
    p_dream.add_argument("--enqueue", metavar="ID", help="Prioritize a specific dataset in the HF queue.")

    p_sov = sub.add_parser("sovereign", help="Launch the high-integrity development workspace (Docker).")
    p_sov.add_argument("--build", action="store_true", help="Force rebuild the sovereign image.")
    p_sov.add_argument("--migrate", metavar="PATH", help="Migrate the repository to a target path (e.g. USB drive).")

    return parser


def dispatch(args: argparse.Namespace, raw_argv: list[str]) -> int:
    cmd = args.command
    if cmd is None:
        # No subcommand → forward everything that follows top-level flags to Medulla.
        # Legacy behavior: if the first arg is not a known Medulla subcommand, prefix with 'thought'.
        leftover = [a for a in raw_argv if a not in {"--log-level", args.log_level, "--log-format", args.log_format}]
        if not leftover:
            build_parser().print_help()
            return 0
        
        # Check if first arg is a known Medulla command
        if leftover[0] not in MEDULLA_PASSTHROUGH and leftover[0] not in {"status", "server", "reset"}:
            leftover = ["thought"] + leftover
            
        emit_event("medulla.passthrough", argc=len(leftover))
        return run_medulla(leftover).returncode

    remainder = list(getattr(args, "args", []) or [])

    if cmd in MEDULLA_PASSTHROUGH:
        return cmd_passthrough(cmd, remainder)
    if cmd == "status":
        return cmd_status(args, remainder)
    if cmd == "reset":
        return cmd_reset(remainder, assume_yes=args.yes)
    if cmd == "telegram":
        return cmd_telegram(remainder)
    if cmd == "live":
        return cmd_live(remainder)
    if cmd == "dream":
        return cmd_dream(args)
    if cmd == "sovereign":
        return cmd_sovereign(args)

    LOG.error("unknown command: %s", cmd)
    return 2


def main(argv: Optional[list[str]] = None) -> int:
    raw_argv = list(sys.argv[1:] if argv is None else argv)
    sys.path.append(str(CORTEX_DIR))
    load_env()
    parser = build_parser()

    # Legacy fallback: if first positional isn't a known command, assume it's a 'thought' task.
    # This allows `./chyren "hello"` to be treated as `./chyren thought "hello"`.
    known_subcommands = set(MEDULLA_PASSTHROUGH) | {
        "status", "reset", "telegram", "live", "dream", "sovereign", "server", "completions", "man"
    }
    
    cursor = 0
    while cursor < len(raw_argv):
        arg = raw_argv[cursor]
        if arg in {"--log-level", "--log-format"}:
            cursor += 2
            continue
        if arg.startswith("-"):
            cursor += 1
            continue
        # First positional argument found
        if arg not in known_subcommands:
            raw_argv.insert(cursor, "thought")
        break
    else:
        # No positional argument found - if raw_argv is empty or only flags, 
        # the parser will handle showing help.
        pass

    args = parser.parse_args(raw_argv)
    configure_logging(args.log_level, args.log_format)
    emit_event("cli.start", argv=raw_argv, version=VERSION)
    # Phase 0: Sovereign Environment Sanity Check
    if not os.getenv("CHYREN_BYPASS_HARDENING"):
        if not Path("~/.omega/one-true.env").expanduser().exists():
            # Soft warning instead of hard exit to maintain usability
            LOG.warning("UNPROTECTED ENVIRONMENT: Sovereign Vault (~/.omega/one-true.env) not found.")
        
        # Verify Yettragrammaton Integrity
        ledger_path = STATE_DIR / "master_ledger.json"
        if ledger_path.exists():
            try:
                with open(ledger_path, "r") as f:
                    data = json.load(f)
                    if data.get("entries") and data["entries"][-1].get("signature") != "R.W.Ϝ.Y.":
                        LOG.warning("INTEGRITY ALERT: Master Ledger signature mismatch. Sovereign seal lost.")
            except Exception:
                pass

    try:
        rc = dispatch(args, raw_argv)
    except SystemExit:
        raise
    except KeyboardInterrupt:
        LOG.warning("interrupted")
        emit_event("cli.interrupt")
        return 130
    except Exception as exc:
        LOG.error("unhandled error: %s", exc, exc_info=True)
        emit_event("cli.error", error=str(exc))
        return 1
    emit_event("cli.end", returncode=rc)
    return rc


if __name__ == "__main__":
    sys.exit(main())
