#!/usr/bin/env bash
# Chyren — single front door to the Sovereign Intelligence Orchestrator.
#
# ENTERPRISE EDITION
# This launcher handles path resolution for the standardized monorepo.

set -euo pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MEDULLA_DIR="$REPO_DIR/src/medulla/kernel"
TUI_RELEASE="$MEDULLA_DIR/target/release/chyren-tui"
TUI_DEBUG="$MEDULLA_DIR/target/debug/chyren-tui"

# Source sovereign vault if present
for env_file in \
  "$REPO_DIR/vault/secrets/sovereign.env" \
  "$REPO_DIR/vault/secrets/env.local" \
  "$REPO_DIR/.env"
do
  if [[ -f "$env_file" ]]; then
    set -a
    source "$env_file"
    set +a
    break
  fi
done

# Locate the TUI binary
if [[ -x "$TUI_RELEASE" ]]; then
  TUI_BIN="$TUI_RELEASE"
elif [[ -x "$TUI_DEBUG" ]]; then
  TUI_BIN="$TUI_DEBUG"
else
  echo "[chyren] TUI binary not found — building..."
  (cd "$MEDULLA_DIR" && cargo build --release -p chyren-tui)
  TUI_BIN="$TUI_RELEASE"
fi

export CHYREN_REPO_DIR="$REPO_DIR"
export CHYREN_BIN="$REPO_DIR/chyren"

# Headless escape hatch
if [[ $# -gt 0 ]]; then
  exec "$REPO_DIR/tools/chyren-legacy" "$@"
fi

exec "$TUI_BIN"
