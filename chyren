def cmd_passthrough(name: str, remainder: list[str]) -> int:
    emit_event("medulla.dispatch", command=name, argc=len(remainder))
    return run_medulla([name, *remainder]).returncode





def cmd_sovereign(args: argparse.Namespace) -> int:
    """Build or enter the high-integrity sovereign workspace."""
    sov_dir = REPO_DIR / "ops" / "sovereign"
    
    if args.migrate:
        target = Path(args.migrate).resolve()
        print(f"─── MIGRATING CHYREN TO SOVEREIGN STORAGE ───")
        if not target.is_dir():
            print(f"Error: Target path '{target}' is not a directory.")
            return 1
        
        dest = target / "Chyren"
        if dest.exists():
            print(f"Warning: Destination '{dest}' already exists.")
            ans = input("Overwrite? [y/N]: ").lower()
            if ans != 'y':
                return 1
            shutil.rmtree(dest)
        
        print(f"→ Copying repository to {dest}...")
        # Use rsync if available for efficiency, otherwise shutil.copytree
        try:
            subprocess.run(["rsync", "-a", "--exclude", "node_modules", "--exclude", "target", "--exclude", ".vercel", str(REPO_DIR) + "/", str(dest)], check=True)
        except (subprocess.CalledProcessError, FileNotFoundError):
            shutil.copytree(REPO_DIR, dest, ignore=shutil.ignore_patterns("node_modules", "target", ".vercel", ".git"))
        
        print(f"✓ Migration complete. To start, cd into {dest} and run './chyren sovereign --build'")
        return 0

    if not (sov_dir / "docker-compose.yml").exists():
        print("Error: ops/sovereign configuration not found.")
        return 1

    print("─── CHYREN SOVEREIGN WORKSPACE ───")
    # Ensure secrets directory exists for mounting
    secrets_dir = Path("~/.omega").expanduser()
    if not secrets_dir.exists():
        print(f"Warning: {secrets_dir} not found. Some functionality may be limited.")
    
    cmd_base = ["docker", "compose", "-f", str(sov_dir / "docker-compose.yml")]
    
    if args.build:
        print("→ Building sovereign image (this may take several minutes)...")
        subprocess.run(cmd_base + ["build"], check=True)
    
    print("→ Entering sovereign shell...")
    try:
        # We use 'run' instead of 'up' to provide an interactive shell by default
        subprocess.run(cmd_base + ["run", "--rm", "chyren"], check=True)
    except subprocess.CalledProcessError:
        print("Error: Failed to launch workspace.")
        return 1
    return 0


