#!/usr/bin/env python3
"""
Chyren — Sovereign Intelligence Orchestrator (brain stem CLI).

This is the user-facing entry point for the Chyren stack. It dispatches to the
Medulla Rust runtime for all live requests and to Python maintenance scripts
during `dream` cycles.

Routing map:
  thought / sense / verify / identity            → Medulla (sovereign reasoning)
  action  / flex / shard / ingest / memory       → Medulla (execution pipeline)
  status / reset                                 → Medulla subcommands
  live                                           → Medulla API + Next.js dev
  telegram                                       → Medulla Telegram gateway
  dream                                          → Python maintenance (synthesis + catalog)
"""

from __future__ import annotations

import argparse
import errno
import json
import logging
import os
import shutil
import signal
import subprocess
import sys
import time
import uuid
from contextlib import contextmanager
from datetime import datetime, timezone
from pathlib import Path
from typing import Iterator, Optional, Sequence

VERSION = "1.0.0"

REPO_DIR = Path(__file__).resolve().parent
CORTEX_DIR = REPO_DIR / "cortex"
MEDULLA_DIR = REPO_DIR / "medulla"
STATE_DIR = REPO_DIR / "state"
EVENTS_LOG = STATE_DIR / "cli_events.jsonl"
DREAM_LOCK = STATE_DIR / ".dream.lock"

LOG = logging.getLogger("chyren")

MEDULLA_REASONING_CMDS = {"thought", "sense", "verify", "identity"}
MEDULLA_EXECUTION_CMDS = {"action", "flex", "shard", "ingest", "memory", "solve", "discipline"}
MEDULLA_PASSTHROUGH = MEDULLA_REASONING_CMDS | MEDULLA_EXECUTION_CMDS

SESSION_ID = uuid.uuid4().hex[:12]


# ─── Environment loading ──────────────────────────────────────────────────────

def load_env() -> None:
    """Load secrets from well-known env files (highest priority first)."""
    candidates = [
        Path("~/.omega_keys.env").expanduser(),
        Path("~/.omega/one-true.env").expanduser(),
        Path("~/OMEGA_WORKSPACE/VAULT/one-true.env").expanduser(),
    ]
    for path in candidates:
        if not path.is_file():
            continue
        try:
            with path.open() as f:
                for line in f:
                    line = line.strip()
                    if not line or line.startswith("#") or "=" not in line:
                        continue
                    key, _, val = line.partition("=")
                    key = key.strip()
                    val = val.strip().strip('"').strip("'")
                    if key and key not in os.environ:
                        os.environ[key] = val
        except OSError as exc:
            LOG.warning("env file %s unreadable: %s", path, exc)


# ─── Logging + telemetry ──────────────────────────────────────────────────────

class JsonFormatter(logging.Formatter):
    def format(self, record: logging.LogRecord) -> str:
        payload = {
            "ts": datetime.now(timezone.utc).isoformat(),
            "level": record.levelname,
            "logger": record.name,
            "msg": record.getMessage(),
            "session": SESSION_ID,
        }
        if record.exc_info:
            payload["exc"] = self.formatException(record.exc_info)
        return json.dumps(payload, separators=(",", ":"))


def configure_logging(level_name: str, log_format: str) -> None:
    level = getattr(logging, level_name.upper(), logging.INFO)
    handler = logging.StreamHandler(sys.stderr)
    if log_format == "json":
        handler.setFormatter(JsonFormatter())
    else:
        handler.setFormatter(logging.Formatter("%(levelname)s %(message)s"))
    root = logging.getLogger()
    root.handlers.clear()
    root.addHandler(handler)
    root.setLevel(level)


def emit_event(event: str, **fields: object) -> None:
    """Append a structured event to state/cli_events.jsonl. Best-effort."""
    if os.getenv("CHYREN_TELEMETRY_DISABLE", "").lower() in ("1", "true", "yes"):
        return
    payload = {
        "ts": datetime.now(timezone.utc).isoformat(),
        "session": SESSION_ID,
        "event": event,
        **fields,
    }
    try:
        STATE_DIR.mkdir(parents=True, exist_ok=True)
        with EVENTS_LOG.open("a", encoding="utf-8") as f:
            f.write(json.dumps(payload, separators=(",", ":")) + "\n")
    except OSError as exc:
        LOG.debug("telemetry write failed: %s", exc)


# ─── Process helpers ──────────────────────────────────────────────────────────

def require_tool(tool: str) -> None:
    if shutil.which(tool) is None:
        raise SystemExit(f"[chyren] required tool not found on PATH: {tool}")


def run_subprocess(cmd: Sequence[str], *, cwd: Optional[Path] = None) -> subprocess.CompletedProcess:
    LOG.debug("exec: %s (cwd=%s)", " ".join(cmd), cwd or Path.cwd())
    return subprocess.run(list(cmd), cwd=str(cwd) if cwd else None)


def medulla_bin(name: str = "chyren") -> Path:
    """Resolve a Medulla binary path, optionally auto-building it."""
    if name == "chyren":
        env_key = "CHYREN_MEDULLA_BIN"
        pkg = "omega-cli"
    else:
        env_key = f"CHYREN_{name.upper().replace('-', '_')}_BIN"
        pkg = f"omega-{name.split('-')[0]}"

    default = MEDULLA_DIR / "target" / "release" / name
    path = Path(os.getenv(env_key, str(default)))

    if not path.exists():
        root_target = REPO_DIR / "target" / "release" / name
        if root_target.exists():
            path = root_target

    if not path.exists():
        if os.getenv("CHYREN_AUTO_BUILD", "").lower() not in ("1", "true", "yes"):
            raise SystemExit(
                f"[chyren] Medulla binary '{name}' not found at {path}.\n"
                f"  Build it: cd medulla && cargo build --release -p {pkg}\n"
                "  Or set CHYREN_AUTO_BUILD=1."
            )
        require_tool("cargo")
        LOG.warning("Building Medulla binary '%s' (release)...", name)
        emit_event("auto_build.start", binary=name, package=pkg)
        res = run_subprocess(
            ["cargo", "build", "--release", "-p", pkg, "--bin", name],
            cwd=MEDULLA_DIR,
        )
        emit_event("auto_build.end", binary=name, returncode=res.returncode)
        if res.returncode != 0 or not path.exists():
            raise SystemExit(f"[chyren] cargo build failed for '{name}'.")
    return path


def run_medulla(args: Sequence[str], bin_name: str = "chyren") -> subprocess.CompletedProcess:
    binary = medulla_bin(bin_name)
    return run_subprocess([str(binary), *args])


# ─── Lock file (for dream cycle) ──────────────────────────────────────────────

@contextmanager
def exclusive_lock(path: Path) -> Iterator[None]:
    """File-based lock. Refuses to overwrite a live lock; cleans stale ones."""
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    try:
        fd = os.open(str(path), os.O_CREAT | os.O_EXCL | os.O_WRONLY, 0o644)
    except OSError as exc:
        if exc.errno != errno.EEXIST:
            raise
        # Lock exists — check if owner is alive
        try:
            existing = path.read_text().strip()
            owner_pid = int(existing.split(":", 1)[0])
        except (OSError, ValueError):
            owner_pid = -1
        if owner_pid > 0 and _pid_alive(owner_pid):
            raise SystemExit(
                f"[chyren] dream cycle already running (pid={owner_pid}). "
                f"If you're sure it's dead, remove {path}."
            )
        LOG.warning("Stale lock at %s (pid=%s) — reclaiming.", path, owner_pid)
        try:
            path.unlink()
        except OSError:
            pass
        fd = os.open(str(path), os.O_CREAT | os.O_EXCL | os.O_WRONLY, 0o644)

    try:
        os.write(fd, f"{os.getpid()}:{SESSION_ID}\n".encode())
        os.close(fd)
        yield
    finally:
        try:
            path.unlink()
        except OSError:
            pass


def _pid_alive(pid: int) -> bool:
    try:
        os.kill(pid, 0)
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    return True


# ─── Subcommand handlers ──────────────────────────────────────────────────────

def cmd_passthrough(name: str, remainder: list[str]) -> int:
    emit_event("medulla.dispatch", command=name, argc=len(remainder))
    return run_medulla([name, *remainder]).returncode


def cmd_status(remainder: list[str]) -> int:
    print("--- Unified Brain State ---")
    print("Hemisphere R (Medulla): HIGH-SPEED SOVEREIGN RUNTIME — ACTIVE")
    print("Yettragrammaton: R.W.Ϝ.Y.")
    print("Bridge (Stem): ACTIVE")
    emit_event("status.requested")
    return run_medulla(["status", *remainder]).returncode


def cmd_reset(remainder: list[str], assume_yes: bool) -> int:
    allow_env = os.getenv("CHYREN_ALLOW_RESET", "").lower() in ("1", "true", "yes")
    if not (allow_env or assume_yes):
        sys.stderr.write(
            "[chyren] reset is destructive (ledger truncation).\n"
            "  Re-run with --yes, or set CHYREN_ALLOW_RESET=1.\n"
        )
        emit_event("reset.refused", reason="no_confirmation")
        return 2
    if not assume_yes and sys.stdin.isatty():
        ans = input("Type 'reset' to confirm ledger reset: ").strip()
        if ans != "reset":
            sys.stderr.write("[chyren] reset aborted.\n")
            emit_event("reset.refused", reason="prompt_aborted")
            return 2
    emit_event("reset.dispatch")
    return run_medulla(["reset", *remainder]).returncode


def cmd_telegram(remainder: list[str]) -> int:
    LOG.info("Starting Telegram Gateway (chyren-telegram)...")
    emit_event("telegram.start")
    return run_medulla(remainder, bin_name="chyren-telegram").returncode


def cmd_live(remainder: list[str]) -> int:
    LOG.info("Bootstrapping Live Hub (Next.js + Medulla API)...")
    require_tool("npm")
    binary = medulla_bin()

    medulla_proc: Optional[subprocess.Popen] = None
    web_proc: Optional[subprocess.Popen] = None
    received_signal = {"sig": None}

    def _propagate(sig: int, _frame: object) -> None:
        received_signal["sig"] = sig
        LOG.info("live: received signal %s — shutting down children", sig)
        for proc in (web_proc, medulla_proc):
            if proc and proc.poll() is None:
                try:
                    proc.send_signal(signal.SIGTERM)
                except ProcessLookupError:
                    pass

    prev_int = signal.signal(signal.SIGINT, _propagate)
    prev_term = signal.signal(signal.SIGTERM, _propagate)

    emit_event("live.start")
    try:
        medulla_proc = subprocess.Popen([str(binary), "server", *remainder])
        web_proc = subprocess.Popen(
            ["npm", "run", "dev"],
            cwd=str(REPO_DIR / "web"),
        )
        # Wait for whichever exits first.
        while True:
            time.sleep(0.5)
            if medulla_proc.poll() is not None:
                LOG.warning("live: Medulla exited (code=%s)", medulla_proc.returncode)
                break
            if web_proc.poll() is not None:
                LOG.warning("live: web exited (code=%s)", web_proc.returncode)
                break
            if received_signal["sig"] is not None:
                break
        rc = medulla_proc.returncode if medulla_proc.returncode is not None else (web_proc.returncode or 0)
        return rc
    finally:
        signal.signal(signal.SIGINT, prev_int)
        signal.signal(signal.SIGTERM, prev_term)
        for proc in (web_proc, medulla_proc):
            if proc and proc.poll() is None:
                try:
                    proc.send_signal(signal.SIGTERM)
                    proc.wait(timeout=5)
                except subprocess.TimeoutExpired:
                    proc.kill()
                except ProcessLookupError:
                    pass
        emit_event("live.stop", signal=received_signal["sig"])


def cmd_dream(_remainder: list[str]) -> int:
    LOG.info("Entering Dream State (Autonomous Maintenance)...")
    emit_event("dream.start")
    with exclusive_lock(DREAM_LOCK):
        identity = CORTEX_DIR / "chyren_py" / "identity_synthesis.py"
        catalog = CORTEX_DIR / "ops" / "scripts" / "catalog_registrar.py"
        for script in (identity, catalog):
            if not script.is_file():
                emit_event("dream.fail", missing=str(script))
                raise SystemExit(f"[chyren] dream script missing: {script}")
        r1 = run_subprocess([sys.executable, str(identity)])
        r2 = run_subprocess([sys.executable, str(catalog)])
        if r1.returncode != 0 or r2.returncode != 0:
            emit_event("dream.fail", identity=r1.returncode, catalog=r2.returncode)
            raise SystemExit("[chyren] dream cycle failed.")
    LOG.info("Dream cycle complete. Memory indexed.")
    emit_event("dream.complete")
    return 0


# ─── Argparse wiring ──────────────────────────────────────────────────────────

def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="chyren",
        description="Chyren brain stem — dispatches to the Medulla sovereign runtime.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "Environment:\n"
            "  CHYREN_LOG_LEVEL          DEBUG/INFO/WARN/ERROR (default: INFO)\n"
            "  CHYREN_LOG_FORMAT         text/json (default: text)\n"
            "  CHYREN_TELEMETRY_DISABLE  Set to 1 to skip state/cli_events.jsonl writes\n"
            "  CHYREN_AUTO_BUILD         Set to 1 to auto cargo-build missing binaries\n"
            "  CHYREN_MEDULLA_BIN        Override path to chyren Medulla binary\n"
            "  CHYREN_ALLOW_RESET        Set to 1 to permit reset without --yes\n"
        ),
    )
    parser.add_argument("--version", action="version", version=f"chyren {VERSION}")
    parser.add_argument(
        "--log-level",
        default=os.getenv("CHYREN_LOG_LEVEL", "INFO"),
        help="DEBUG/INFO/WARN/ERROR (default INFO; or CHYREN_LOG_LEVEL).",
    )
    parser.add_argument(
        "--log-format",
        default=os.getenv("CHYREN_LOG_FORMAT", "text"),
        choices=("text", "json"),
        help="Log line format (default text; or CHYREN_LOG_FORMAT).",
    )

    sub = parser.add_subparsers(dest="command", metavar="<command>")

    def _add_passthrough(name: str, help_text: str) -> None:
        p = sub.add_parser(name, help=help_text, add_help=False)
        p.add_argument("args", nargs=argparse.REMAINDER, help="Forwarded to Medulla")

    for n in sorted(MEDULLA_REASONING_CMDS):
        _add_passthrough(n, f"Sovereign reasoning: {n}")
    for n in sorted(MEDULLA_EXECUTION_CMDS):
        _add_passthrough(n, f"Execution pipeline: {n}")

    p_status = sub.add_parser("status", help="Print unified brain status.")
    p_status.add_argument("args", nargs=argparse.REMAINDER)

    p_reset = sub.add_parser("reset", help="Reset the Medulla ledger (destructive).")
    p_reset.add_argument("--yes", action="store_true", help="Skip the confirmation prompt.")
    p_reset.add_argument("args", nargs=argparse.REMAINDER)

    p_telegram = sub.add_parser("telegram", help="Run the Medulla Telegram gateway binary.")
    p_telegram.add_argument("args", nargs=argparse.REMAINDER)

    p_live = sub.add_parser("live", help="Boot Medulla API + Next.js dev server.")
    p_live.add_argument("args", nargs=argparse.REMAINDER)

    sub.add_parser("dream", help="Maintenance mode: identity synthesis + catalog indexing.")

    return parser


def dispatch(args: argparse.Namespace, raw_argv: list[str]) -> int:
    cmd = args.command
    if cmd is None:
        # No subcommand → forward everything that follows top-level flags to Medulla.
        leftover = [a for a in raw_argv if a not in {"--log-level", args.log_level, "--log-format", args.log_format}]
        if not leftover:
            build_parser().print_help()
            return 0
        emit_event("medulla.passthrough", argc=len(leftover))
        return run_medulla(leftover).returncode

    remainder = list(getattr(args, "args", []) or [])

    if cmd in MEDULLA_PASSTHROUGH:
        return cmd_passthrough(cmd, remainder)
    if cmd == "status":
        return cmd_status(remainder)
    if cmd == "reset":
        return cmd_reset(remainder, assume_yes=args.yes)
    if cmd == "telegram":
        return cmd_telegram(remainder)
    if cmd == "live":
        return cmd_live(remainder)
    if cmd == "dream":
        return cmd_dream(remainder)

    LOG.error("unknown command: %s", cmd)
    return 2


def main(argv: Optional[list[str]] = None) -> int:
    raw_argv = list(sys.argv[1:] if argv is None else argv)
    load_env()
    parser = build_parser()
    args = parser.parse_args(raw_argv)
    configure_logging(args.log_level, args.log_format)
    emit_event("cli.start", argv=raw_argv, version=VERSION)
    try:
        rc = dispatch(args, raw_argv)
    except SystemExit:
        raise
    except KeyboardInterrupt:
        LOG.warning("interrupted")
        emit_event("cli.interrupt")
        return 130
    except Exception as exc:
        LOG.error("unhandled error: %s", exc, exc_info=True)
        emit_event("cli.error", error=str(exc))
        return 1
    emit_event("cli.end", returncode=rc)
    return rc


if __name__ == "__main__":
    sys.exit(main())
