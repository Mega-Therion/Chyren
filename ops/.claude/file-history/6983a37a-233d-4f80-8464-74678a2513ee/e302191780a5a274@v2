#!/usr/bin/env bash
set -e
NEW=/home/mega/.omega/runtime-src/omega-rust/target/release/omega-gateway
echo "Installing new gateway binary..."
sudo cp "$NEW" /usr/local/bin/omega-gateway
echo "Restarting service..."
sudo systemctl restart omega-gateway
sleep 3
echo "Gateway health:"
curl -s http://localhost:8787/health
echo ""
echo "Gateway version in binary:"
strings /usr/local/bin/omega-gateway | grep -i "pool_idle\|0\.1\." | head -3
echo "Done."
