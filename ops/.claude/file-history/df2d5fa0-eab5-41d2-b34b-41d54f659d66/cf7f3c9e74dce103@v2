import { NextRequest, NextResponse } from 'next/server';
import { getProviderHealthSnapshot, getProviderOrder } from '@/lib/provider-routing';
import { resolveInteractionMode } from '@/lib/omega/policy';

// Provider health exposes which API keys are configured — operator only (#16, #17)
export async function GET(req: NextRequest) {
  const mode = resolveInteractionMode(req);
  if (mode !== 'operator') {
    return NextResponse.json({ error: 'Unauthorised' }, { status: 401 });
  }

  const providerHealth = getProviderHealthSnapshot();
  return NextResponse.json({
    providerHealth,
    providerOrder: getProviderOrder(),
  });
}
