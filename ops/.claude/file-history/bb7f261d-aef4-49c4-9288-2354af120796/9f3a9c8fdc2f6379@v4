import { NextRequest, NextResponse } from 'next/server';
import { resolveInteractionMode } from '@/lib/omega/policy';
import {
  safeErrorMessage,
  stripMarkdownForVoice,
  checkTTSRateLimit,
  getCircuitBreaker,
  withRetryBackoff,
  generateCorrelationId,
  CORRELATION_HEADER,
} from '@/lib/hardening';

/* ── ElevenLabs (primary) ── */
const ELEVEN_KEY = process.env.ELEVENLABS_API_KEY ?? '';
const ELEVEN_VOICE_ID = 'onwK4e9ZLuTAKqWW03F9'; // "Daniel" — deep, authoritative, conversational
const ELEVEN_MODEL = 'eleven_turbo_v2_5'; // lowest latency, optimized for conversational AI

/* ──  (fallback) ── */
const _KEYS = [
  process.env._API_KEY_4,
  process.env._API_KEY_2,
  process.env._API_KEY,
].filter(Boolean) as string[];

const TTS_MODEL = '-2.5-flash-preview-tts';
const TTS_VOICE = 'Charon';

// elevenLabsTTS replaced by elevenLabsTTSWithTimeout below (circuit breaker + timeout)

async function TTS(text: string): Promise<{ wav: Buffer } | null> {
  for (const key of _KEYS) {
    try {
      const res = await fetch(
        `https://generativelanguage.googleapis.com/v1beta/models/${TTS_MODEL}:generateContent?key=${key}`,
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            contents: [{ parts: [{ text }] }],
            generationConfig: {
              responseModalities: ['AUDIO'],
              speechConfig: {
                voiceConfig: { prebuiltVoiceConfig: { voiceName: TTS_VOICE } },
              },
            },
          }),
        }
      );

      if (!res.ok) { console.warn(`[TTS]  key failed — status ${res.status}`); continue; }

      const data = await res.json();
      // eslint-disable-next-line @typescript-eslint/no-explicit-any
      const part = data.candidates?.[0]?.content?.parts?.find((p: any) => p.inlineData);
      if (!part?.inlineData?.data) continue;

      const pcm = Buffer.from(part.inlineData.data, 'base64');
      const wav = pcmToWav(pcm);
      return { wav };
    } catch (e) {
      console.warn('[TTS]  key error:', e);
    }
  }
  return null;
}

function pcmToWav(pcmBuffer: Buffer, sampleRate = 24000, channels = 1, bitDepth = 16): Buffer {
  const byteRate = sampleRate * channels * (bitDepth / 8);
  const blockAlign = channels * (bitDepth / 8);
  const header = Buffer.alloc(44);
  header.write('RIFF', 0);
  header.writeUInt32LE(36 + pcmBuffer.length, 4);
  header.write('WAVE', 8);
  header.write('fmt ', 12);
  header.writeUInt32LE(16, 16);
  header.writeUInt16LE(1, 20);
  header.writeUInt16LE(channels, 22);
  header.writeUInt32LE(sampleRate, 24);
  header.writeUInt32LE(byteRate, 28);
  header.writeUInt16LE(blockAlign, 32);
  header.writeUInt16LE(bitDepth, 34);
  header.write('data', 36);
  header.writeUInt32LE(pcmBuffer.length, 40);
  return Buffer.concat([header, pcmBuffer]);
}

const TTS_TIMEOUT_MS = 20_000;

async function elevenLabsTTSWithTimeout(text: string): Promise<Buffer | null> {
  const cb = getCircuitBreaker('elevenlabs');
  if (cb.isOpen) return null;
  try {
    const result = await withRetryBackoff(
      async () => {
        const controller = new AbortController();
        const timer = setTimeout(() => controller.abort(), TTS_TIMEOUT_MS);
        try {
          const res = await fetch(
            `https://api.elevenlabs.io/v1/text-to-speech/${ELEVEN_VOICE_ID}`,
            {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'xi-api-key': ELEVEN_KEY },
              body: JSON.stringify({
                text,
                model_id: ELEVEN_MODEL,
                voice_settings: { stability: 0.5, similarity_boost: 0.75, style: 0.4, use_speaker_boost: true },
              }),
              signal: controller.signal,
            },
          );
          if (!res.ok) throw new Error(`ElevenLabs ${res.status}`);
          return Buffer.from(await res.arrayBuffer());
        } finally {
          clearTimeout(timer);
        }
      },
      { maxAttempts: 2, baseDelayMs: 300 },
    );
    cb.recordSuccess();
    return result;
  } catch (e) {
    cb.recordFailure();
    console.warn('[TTS] ElevenLabs failed:', e);
    return null;
  }
}

export async function POST(req: NextRequest) {
  const correlationId = req.headers.get(CORRELATION_HEADER) ?? generateCorrelationId();

  // Rate limit — TTS is expensive (#V9, #V1)
  const mode = resolveInteractionMode(req);
  const isOperator = mode === 'operator';
  const clientIp = req.headers.get('x-forwarded-for')?.split(',')[0].trim() ?? 'unknown';
  const rateResult = checkTTSRateLimit(clientIp, isOperator);
  if (!rateResult.allowed) {
    return NextResponse.json(
      { error: safeErrorMessage(429) },
      { status: 429, headers: { 'Retry-After': String(Math.ceil((rateResult.resetAt - Date.now()) / 1000)) } },
    );
  }

  try {
    const body = await req.json() as { text?: string };
    if (!body?.text?.trim()) return NextResponse.json({ error: 'No text provided' }, { status: 400 });

    // Strip markdown before synthesis — TTS reads `**bold**` literally (#V6)
    const safeText = stripMarkdownForVoice(body.text);

    if (!safeText) return NextResponse.json({ error: 'No speakable text after processing' }, { status: 400 });

    // Try ElevenLabs first (with circuit breaker + timeout)
    const elevenAudio = await elevenLabsTTSWithTimeout(safeText);
    if (elevenAudio) {
      return NextResponse.json(
        { audio: elevenAudio.toString('base64'), mimeType: 'audio/mpeg', provider: 'elevenlabs', correlationId },
        { headers: { [CORRELATION_HEADER]: correlationId } },
      );
    }

    // Fallback to  TTS
    const Result = await TTS(safeText);
    if (Result) {
      return NextResponse.json(
        { audio: Result.wav.toString('base64'), mimeType: 'audio/wav', provider: '', correlationId },
        { headers: { [CORRELATION_HEADER]: correlationId } },
      );
    }

    return NextResponse.json({ error: 'TTS unavailable — all providers failed' }, { status: 503 });
  } catch (err) {
    return NextResponse.json({ error: safeErrorMessage(500, err) }, { status: 500 });
  }
}
