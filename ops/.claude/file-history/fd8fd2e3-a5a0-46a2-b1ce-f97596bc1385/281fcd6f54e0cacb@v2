            SELECT content, created_at
            FROM omega_memory_entries
            ORDER BY created_at ASC
        """)
        rows = cur.fetchall()
        if rows:
            sections.append(f"\n\n{'='*70}\nSOURCE: NEON DB вЂ” omega_memory_entries ({len(rows)} entries)\n{'='*70}\n")
