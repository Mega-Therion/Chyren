@tailwind base;
@tailwind components;
@tailwind utilities;

@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@300;400;500&display=swap');

:root {
  --glass-bg: rgba(3, 7, 18, 0.6);
  --glass-border: rgba(99, 102, 241, 0.2);
  --glass-blur: blur(20px);
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html, body {
  height: 100%;
  overflow: hidden;
  background: radial-gradient(circle at 50% 50%, #1e1b4b 0%, #030712 70%);
}

body {
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  -webkit-font-smoothing: antialiased;
  color: #e2e8f0;
}

.glass-panel {
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  border: 1px solid var(--glass-border);
  border-radius: 12px;
}

/* Scanline overlay */
body::after {
  content: '';
  position: fixed;
  inset: 0;
  background: repeating-linear-gradient(
    0deg,
    transparent,
    transparent 2px,
    rgba(0, 0, 0, 0.05) 2px,
    rgba(0, 0, 0, 0.05) 4px
  );
  pointer-events: none;
  z-index: 9999;
  opacity: 0.3;
}

.font-mono {
  font-family: 'JetBrains Mono', 'Courier New', monospace;
}

/* Scanline overlay */
body::after {
  content: '';
  position: fixed;
  inset: 0;
  background: repeating-linear-gradient(
    0deg,
    transparent,
    transparent 2px,
    rgba(0, 0, 0, 0.03) 2px,
    rgba(0, 0, 0, 0.03) 4px
  );
  pointer-events: none;
  z-index: 9999;
}

/* Scrollbar */
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: rgba(99, 102, 241, 0.3); border-radius: 2px; }
::-webkit-scrollbar-thumb:hover { background: rgba(99, 102, 241, 0.5); }

/* Focus */
input:focus, textarea:focus, button:focus { outline: none; }

/* Omega glow */
.omega-glow {
  text-shadow: 0 0 20px rgba(99, 102, 241, 0.8), 0 0 40px rgba(99, 102, 241, 0.4);
}

/* Status bar */
.status-bar {
  background: rgba(3, 7, 18, 0.9);
  border-bottom: 1px solid rgba(99, 102, 241, 0.15);
}

/* Terminal panel */
.terminal-panel {
  background: rgba(3, 7, 18, 0.95);
  border: 1px solid rgba(99, 102, 241, 0.12);
}

/* Input area */
.input-area {
  background: rgba(15, 23, 42, 0.8);
  border: 1px solid rgba(99, 102, 241, 0.2);
  transition: border-color 0.2s;
}
.input-area:focus-within {
  border-color: rgba(99, 102, 241, 0.5);
  box-shadow: 0 0 0 1px rgba(99, 102, 241, 0.15), 0 0 20px rgba(99, 102, 241, 0.05);
}

/* Message entry */
.msg-user {
  border-left: 2px solid rgba(99, 102, 241, 0.6);
  background: rgba(99, 102, 241, 0.04);
}
.msg-assistant {
  border-left: 2px solid rgba(16, 185, 129, 0.5);
  background: rgba(16, 185, 129, 0.02);
}

/* Cursor blink */
@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}
.cursor { animation: blink 1s step-end infinite; }

/* Fade up */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(6px); }
  to   { opacity: 1; transform: translateY(0); }
}
.fade-up { animation: fadeUp 0.25s ease forwards; }

/* Pulse dot */
@keyframes pulseDot {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%       { opacity: 0.4; transform: scale(0.8); }
}
.pulse-dot { animation: pulseDot 1.4s ease-in-out infinite; }
.pulse-dot:nth-child(2) { animation-delay: 0.2s; }
.pulse-dot:nth-child(3) { animation-delay: 0.4s; }

/* Grid bg */
.grid-bg {
  background-image:
    linear-gradient(rgba(99, 102, 241, 0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(99, 102, 241, 0.04) 1px, transparent 1px);
  background-size: 40px 40px;
}

/* Vercel-style badge */
.badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 10px;
  font-family: 'JetBrains Mono', monospace;
  letter-spacing: 0.05em;
  padding: 2px 8px;
  border-radius: 3px;
  border: 1px solid;
}

.badge-green {
  color: #10b981;
  border-color: rgba(16, 185, 129, 0.3);
  background: rgba(16, 185, 129, 0.06);
}

.badge-indigo {
  color: #818cf8;
  border-color: rgba(129, 140, 248, 0.3);
  background: rgba(129, 140, 248, 0.06);
}

.badge-amber {
  color: #f59e0b;
  border-color: rgba(245, 158, 11, 0.3);
  background: rgba(245, 158, 11, 0.06);
}

.badge-red {
  color: #f87171;
  border-color: rgba(248, 113, 113, 0.3);
  background: rgba(248, 113, 113, 0.06);
}

/* Code blocks in messages */
.msg-content pre {
  background: rgba(0, 0, 0, 0.6);
  border: 1px solid rgba(99, 102, 241, 0.1);
  border-radius: 4px;
  padding: 12px;
  overflow-x: auto;
  margin: 8px 0;
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px;
  line-height: 1.6;
}
.msg-content code {
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px;
  background: rgba(99, 102, 241, 0.12);
  padding: 1px 5px;
  border-radius: 3px;
  color: #a5b4fc;
}
.msg-content pre code {
  background: transparent;
  padding: 0;
  color: inherit;
}
.msg-content p { margin-bottom: 6px; line-height: 1.65; }
.msg-content ul, .msg-content ol { margin: 6px 0 6px 20px; }
.msg-content li { margin: 3px 0; line-height: 1.6; }
.msg-content strong { color: #e2e8f0; font-weight: 600; }
.msg-content h1, .msg-content h2, .msg-content h3 {
  color: #c7d2fe;
  font-weight: 600;
  margin: 10px 0 4px;
}

/* Sidebar */
.sidebar {
  background: rgba(3, 7, 18, 0.98);
  border-right: 1px solid rgba(99, 102, 241, 0.1);
}

/* Brain panel */
.brain-panel {
  background: rgba(3, 7, 18, 0.95);
  border-right: 1px solid rgba(99, 102, 241, 0.1);
}
