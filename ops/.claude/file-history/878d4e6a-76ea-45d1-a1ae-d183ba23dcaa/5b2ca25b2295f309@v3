// ── V2. Correlation ID — full pipeline tracing (#V2, #V8) ────────────────────

export function generateCorrelationId(): string {
  // Use crypto.randomUUID when available (Node 19+, modern browsers), fallback otherwise
  if (typeof crypto !== 'undefined' && typeof crypto.randomUUID === 'function') {
    return crypto.randomUUID();
  }
  // Fallback: manual UUID v4
  return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, (c) => {
    const r = Math.random() * 16 | 0;
    return (c === 'x' ? r : (r & 0x3 | 0x8)).toString(16);
  });
}

export const CORRELATION_HEADER = 'x-omega-correlation-id';

// ── V3. ASR / Audio file validation (#V3) ────────────────────────────────────

const ALLOWED_AUDIO_MIMES = new Set([
  'audio/webm', 'audio/wav', 'audio/wave', 'audio/x-wav',
  'audio/mp3', 'audio/mpeg', 'audio/mp4', 'audio/m4a',
  'audio/ogg', 'audio/flac',
]);

// Max audio file size: 25 MB (Whisper API hard limit is 25 MB)
const MAX_AUDIO_BYTES = 25 * 1024 * 1024;
// Min meaningful audio: 1 KB (anything smaller is silence/noise)
const MIN_AUDIO_BYTES = 1_000;

export interface AudioValidationResult {
  ok: boolean;
  error?: string;
}

export function validateAudioFile(file: File): AudioValidationResult {
  if (!file) return { ok: false, error: 'No audio file provided' };

  if (file.size < MIN_AUDIO_BYTES) {
    return { ok: false, error: 'Audio too short — nothing to transcribe' };
  }

  if (file.size > MAX_AUDIO_BYTES) {
    return { ok: false, error: `Audio file exceeds ${MAX_AUDIO_BYTES / 1024 / 1024} MB limit` };
  }

  // Check MIME type — also check file extension as fallback
  const mimeOk = ALLOWED_AUDIO_MIMES.has(file.type.toLowerCase().split(';')[0].trim());
  const ext = file.name?.split('.').pop()?.toLowerCase() ?? '';
  const extOk = ['webm', 'wav', 'mp3', 'mp4', 'm4a', 'ogg', 'flac'].includes(ext);

  if (!mimeOk && !extOk) {
    return { ok: false, error: `Unsupported audio format: ${file.type || ext}` };
  }

  return { ok: true };
}

// ── V4. Dialog Loop Detection (#V4) ──────────────────────────────────────────
// Detects when the conversation is stuck — repeated confusion or same question.

export class DialogLoopDetector {
  private readonly windowSize: number;
  private readonly similarityThreshold: number;
  private recentMessages: string[];

  constructor(windowSize = 6, similarityThreshold = 0.75) {
    this.windowSize = windowSize;
    this.similarityThreshold = similarityThreshold;
    this.recentMessages = [];
  }

  push(message: string): void {
    this.recentMessages.push(message.toLowerCase().trim());
    if (this.recentMessages.length > this.windowSize) {
      this.recentMessages.shift();
    }
  }

  isLooping(): boolean {
    if (this.recentMessages.length < 3) return false;

    // Check for exact repetition
    const counts = new Map<string, number>();
    for (const m of this.recentMessages) {
      counts.set(m, (counts.get(m) ?? 0) + 1);
      if ((counts.get(m) ?? 0) >= 2) return true;
    }

    // Check for high-similarity repetition using Jaccard similarity on word sets
    const recent = this.recentMessages.slice(-3);
    for (let i = 0; i < recent.length - 1; i++) {
      const a = new Set(recent[i].split(/\s+/));
      const b = new Set(recent[i + 1].split(/\s+/));
      const intersection = new Set([...a].filter(x => b.has(x)));
      const union = new Set([...a, ...b]);
      const jaccard = union.size > 0 ? intersection.size / union.size : 0;
      if (jaccard >= this.similarityThreshold) return true;
    }

    return false;
  }

  reset(): void {
    this.recentMessages = [];
  }
}

// ── V5. Circuit Breaker — per-provider trip/reset (#V5) ──────────────────────

type CircuitState = 'closed' | 'open' | 'half-open';

interface CircuitBreakerOptions {
  failureThreshold?: number;  // failures before tripping
  successThreshold?: number;  // successes in half-open before closing
  timeoutMs?: number;         // how long to stay open before half-open
}

export class CircuitBreaker {
  private state: CircuitState = 'closed';
  private failures = 0;
  private successes = 0;
  private openedAt = 0;

  private readonly failureThreshold: number;
  private readonly successThreshold: number;
  private readonly timeoutMs: number;

  constructor(opts: CircuitBreakerOptions = {}) {
    this.failureThreshold = opts.failureThreshold ?? 3;
    this.successThreshold = opts.successThreshold ?? 2;
    this.timeoutMs = opts.timeoutMs ?? 30_000; // 30s
  }

  get isOpen(): boolean {
    if (this.state === 'open') {
      if (Date.now() - this.openedAt >= this.timeoutMs) {
        this.state = 'half-open';
        this.successes = 0;
        return false; // Allow a probe request
      }
      return true;
    }
    return false;
  }

  recordSuccess(): void {
    if (this.state === 'half-open') {
      this.successes++;
      if (this.successes >= this.successThreshold) {
        this.state = 'closed';
        this.failures = 0;
        this.successes = 0;
      }
    } else {
      this.failures = 0;
    }
  }

  recordFailure(): void {
    this.failures++;
    if (this.failures >= this.failureThreshold) {
      this.state = 'open';
      this.openedAt = Date.now();
    }
  }

  get status(): CircuitState { return this.state; }
}

// Singleton circuit breakers per provider — persists across requests in module scope
const _circuitBreakers = new Map<string, CircuitBreaker>();

export function getCircuitBreaker(name: string): CircuitBreaker {
  if (!_circuitBreakers.has(name)) {
    _circuitBreakers.set(name, new CircuitBreaker());
  }
  return _circuitBreakers.get(name)!;
}

// ── V5b. Exponential Backoff retry wrapper (#V5) ──────────────────────────────

interface RetryOptions {
  maxAttempts?: number;
  baseDelayMs?: number;
  maxDelayMs?: number;
  jitter?: boolean;
}

export async function withRetryBackoff<T>(
  fn: () => Promise<T>,
  opts: RetryOptions = {},
): Promise<T> {
  const maxAttempts = opts.maxAttempts ?? 3;
  const baseDelay = opts.baseDelayMs ?? 200;
  const maxDelay = opts.maxDelayMs ?? 5_000;
  const jitter = opts.jitter ?? true;

  let lastError: unknown;
  for (let attempt = 0; attempt < maxAttempts; attempt++) {
    try {
      return await fn();
    } catch (e) {
      lastError = e;
      if (attempt < maxAttempts - 1) {
        const expDelay = Math.min(baseDelay * Math.pow(2, attempt), maxDelay);
        const delay = jitter ? expDelay * (0.5 + Math.random() * 0.5) : expDelay;
        await new Promise(r => setTimeout(r, delay));
      }
    }
  }
  throw lastError;
}

// ── V6. TTS — strip markdown before synthesis (#V6) ──────────────────────────
// Voice synthesis reads markdown syntax literally — strip it first.

const VOICE_MAX_CHARS = 1_500; // Safe TTS cap — well under ElevenLabs/ limits

export function stripMarkdownForVoice(text: string): string {
  return text
    // Remove headers
    .replace(/^#{1,6}\s+/gm, '')
    // Remove bold/italic
    .replace(/\*{1,3}([^*]+)\*{1,3}/g, '$1')
    .replace(/_{1,3}([^_]+)_{1,3}/g, '$1')
    // Remove inline code
    .replace(/`{1,3}[^`]*`{1,3}/g, '')
    // Remove links — keep label
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    // Remove images
    .replace(/!\[([^\]]*)\]\([^)]+\)/g, '')
    // Remove blockquotes
    .replace(/^>\s+/gm, '')
    // Remove horizontal rules
    .replace(/^[-*_]{3,}\s*$/gm, '')
    // Remove bullet/numbered list markers — keep content
    .replace(/^\s*[-*+]\s+/gm, '')
    .replace(/^\s*\d+\.\s+/gm, '')
    // Collapse multiple newlines to a single pause-friendly period+space
    .replace(/\n{2,}/g, '. ')
    .replace(/\n/g, ' ')
    // Remove HTML tags
    .replace(/<[^>]+>/g, '')
    // Collapse excessive whitespace
    .replace(/\s{2,}/g, ' ')
    .trim()
    // Enforce voice length cap
    .slice(0, VOICE_MAX_CHARS);
}

// ── V7. Health check utilities (#V7) ─────────────────────────────────────────

export interface HealthStatus {
  status: 'ok' | 'degraded' | 'down';
  checks: Record<string, { ok: boolean; detail?: string }>;
  ts: string;
}

export function buildHealthStatus(
  checks: Record<string, boolean | { ok: boolean; detail?: string }>,
): HealthStatus {
  const resolved: Record<string, { ok: boolean; detail?: string }> = {};
  let allOk = true;
  let anyOk = false;

  for (const [key, val] of Object.entries(checks)) {
    const check = typeof val === 'boolean' ? { ok: val } : val;
    resolved[key] = check;
    if (check.ok) anyOk = true;
    else allOk = false;
  }

  const status = allOk ? 'ok' : anyOk ? 'degraded' : 'down';
  return { status, checks: resolved, ts: new Date().toISOString() };
}

// ── V1. TTS rate limiter (separate from chat — different cost profile) (#V9) ──

const _ttsRateBuckets = new Map<string, RateBucket>();
const TTS_RATE_LIMIT_PUBLIC = 10;   // 10 TTS requests/min for public
const TTS_RATE_LIMIT_OPERATOR = 60;

export function checkTTSRateLimit(clientIp: string, isOperator: boolean): RateLimitResult {
  const id = `tts:${isOperator ? 'op' : 'pub'}:${clientIp}`;
  const limit = isOperator ? TTS_RATE_LIMIT_OPERATOR : TTS_RATE_LIMIT_PUBLIC;
  const now = Date.now();

  let bucket = _ttsRateBuckets.get(id);
  if (!bucket || now - bucket.windowStart >= RATE_WINDOW_MS) {
    bucket = { count: 0, windowStart: now };
  }
  bucket.count++;
  _ttsRateBuckets.set(id, bucket);

  return {
    allowed: bucket.count <= limit,
    remaining: Math.max(0, limit - bucket.count),
    resetAt: bucket.windowStart + RATE_WINDOW_MS,
  };
}

// ── V8. Max voice engine restart cap (client-side constant) (#V1) ────────────
// Export so useVoiceEngine can import it — prevents infinite restart storms.
export const MAX_VOICE_RESTARTS = 5;
export const VOICE_RESTART_RESET_MS = 60_000; // reset counter after 1 min of quiet
