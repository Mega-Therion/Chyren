#!/usr/bin/env python3
"""
rovi_family_profiles.py
Embed every family_profiles record into omega_memory_entries.
Idempotent: checks source tag before inserting.
"""
import os, gc, json, psycopg2
from datetime import date
from sentence_transformers import SentenceTransformer

# ── Load VAULT env ────────────────────────────────────────────
from pathlib import Path
import subprocess
VAULT = Path("/home/mega/OMEGA_WORKSPACE/VAULT/one-true.env")
if VAULT.exists():
    res = subprocess.run(
        ["bash", "-c", f"set -a && source {VAULT} && set +a && env"],
        capture_output=True, text=True
    )
    for line in res.stdout.splitlines():
        if "=" in line:
            k, _, v = line.partition("=")
            os.environ.setdefault(k.strip(), v.strip().strip("'\""))

FAMILY_DB = "postgresql://neondb_owner:npg_HbW1Zlkjd7NI@ep-sweet-glade-anvm0pwn-pooler.c-6.us-east-1.aws.neon.tech/neondb?sslmode=require"
OMEGA_DB  = os.getenv("OMEGA_DB_URL") or os.getenv("DATABASE_URL") or FAMILY_DB

SOURCE_TAG = "family_profiles_rovi"
TODAY      = str(date.today())

def build_text(row):
    """Render a family_profiles row into rich narrative text for embedding."""
    (id_, name, last_name, relationship, birthday, deceased, location,
     occupation, partner, aliases, children, fun_facts,
     how_to_greet, ry_notes, notes_for_omega) = row

    full_name = f"{name} {last_name}".strip()
    lines = [f"FAMILY PROFILE: {full_name}"]
    lines.append(f"Relationship to RY: {relationship or 'unspecified'}")
    if birthday:   lines.append(f"Birthday: {birthday}")
    if deceased:   lines.append("Status: DECEASED")
    if location:   lines.append(f"Location: {location}")
    if occupation: lines.append(f"Occupation: {occupation}")
    if partner:    lines.append(f"Partner: {partner}")
    if aliases:
        try:
            al = json.loads(aliases) if isinstance(aliases, str) else aliases
            if al: lines.append(f"Also known as: {', '.join(al)}")
        except Exception:
            lines.append(f"Also known as: {aliases}")
    if children:
        try:
            ch = json.loads(children) if isinstance(children, str) else children
            if ch: lines.append(f"Children: {'; '.join(ch)}")
        except Exception:
            lines.append(f"Children: {children}")
    if fun_facts:
        try:
            ff = json.loads(fun_facts) if isinstance(fun_facts, str) else fun_facts
            if ff: lines.append("Fun facts:\n" + "\n".join(f"  - {f}" for f in ff))
        except Exception:
            lines.append(f"Fun facts: {fun_facts}")
    if how_to_greet: lines.append(f"How to greet: {how_to_greet}")
    if ry_notes:     lines.append(f"RY notes: {ry_notes}")
    if notes_for_omega: lines.append(f"OmegA notes: {notes_for_omega}")

    return "\n".join(lines)

def already_ingested(cur, full_name):
    cur.execute(
        "SELECT 1 FROM public.omega_memory_entries WHERE source = %s AND content LIKE %s LIMIT 1",
        (SOURCE_TAG, f"FAMILY PROFILE: {full_name}%")
    )
    return cur.fetchone() is not None

def main():
    print("Loading embedding model...")
    model = SentenceTransformer("all-MiniLM-L6-v2")
    print("Model ready.")

    fam_conn = psycopg2.connect(FAMILY_DB)
    fam_cur  = fam_conn.cursor()
    fam_cur.execute("""
        SELECT id, name, last_name, relationship, birthday, deceased, location,
               occupation, partner, aliases::text, children::text, fun_facts::text,
               how_to_greet, ry_notes, notes_for_omega
        FROM family_profiles
        ORDER BY id
    """)
    rows = fam_cur.fetchall()
    fam_cur.close()
    fam_conn.close()
    print(f"Fetched {len(rows)} family_profiles records.")

    omega_conn = psycopg2.connect(OMEGA_DB)
    omega_cur  = omega_conn.cursor()

    inserted = 0
    skipped  = 0

    for row in rows:
        name, last_name = row[1], row[2]
        full_name = f"{name} {last_name}".strip()

        if already_ingested(omega_cur, full_name):
            print(f"  SKIP (already in omega_memory): {full_name}")
            skipped += 1
            continue

        text = build_text(row)
        emb  = model.encode(text[:10000]).tolist()

        omega_cur.execute("""
            INSERT INTO public.omega_memory_entries
                (id, content, embedding, source, namespace, domain, importance, created_at, version, confidence)
            VALUES (%s, %s, %s, %s, %s, %s, %s, %s, %s, %s)
        """, (
            os.urandom(8).hex(),
            text,
            emb,
            SOURCE_TAG,
            "family",
            "biography",
            0.92,
            TODAY,
            1,
            1.0
        ))
        print(f"  INSERTED: {full_name}")
        inserted += 1

        if inserted % 10 == 0:
            omega_conn.commit()
            gc.collect()

    omega_conn.commit()
    omega_cur.close()
    omega_conn.close()

    print(f"\n✓ rovi_family_profiles complete: {inserted} inserted, {skipped} skipped.")

if __name__ == "__main__":
    main()
