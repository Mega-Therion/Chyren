def upsert(cur, record):
    name = record["name"]
    # Check if row exists
    cur.execute("SELECT id FROM family_profiles WHERE name = %s", (name,))
    row = cur.fetchone()

    if row:
        # Build SET clause from provided fields (skip 'name')
        fields = {k: v for k, v in record.items() if k != "name"}
        if not fields:
            print(f"  SKIP {name} — no fields to update")
            return
        set_clause = ", ".join(f"{k} = %s" for k in fields)
        set_clause += ", updated_at = %s"
        values = list(fields.values()) + [datetime.now(timezone.utc), name]
        cur.execute(f"UPDATE family_profiles SET {set_clause} WHERE name = %s", values)
        print(f"  UPDATE {name}")
    else:
        # Insert
        fields = record.copy()
        fields["created_at"] = datetime.now(timezone.utc)
        fields["updated_at"] = datetime.now(timezone.utc)
        cols = ", ".join(fields.keys())
        placeholders = ", ".join(["%s"] * len(fields))
        cur.execute(f"INSERT INTO family_profiles ({cols}) VALUES ({placeholders})", list(fields.values()))
        print(f"  INSERT {name}")

