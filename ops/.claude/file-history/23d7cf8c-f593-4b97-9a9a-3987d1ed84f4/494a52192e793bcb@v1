import { NextRequest, NextResponse } from 'next/server';
import { validateChatRequest, checkRateLimit, checkPromptInjection } from '../../../lib/hardening';
import { DialogLoopDetector } from '../../../lib/validators/dialog';

export async function POST(req: NextRequest) {
    const ip = req.ip || 'anonymous';
    
    // 1. Structural Validation
    if (!(await validateChatRequest(req))) {
        return NextResponse.json({ error: 'Unauthorized' }, { status: 403 });
    }

    // 2. Rate Limiting
    if (!checkRateLimit(ip)) {
        return NextResponse.json({ error: 'Rate limit exceeded' }, { status: 429 });
    }

    const body = await req.json();
    const { prompt, history } = body;

    // 3. Prompt Injection Defense
    if (checkPromptInjection(prompt)) {
        return NextResponse.json({ error: 'Security constraint violation' }, { status: 400 });
    }

    // 4. Dialog Loop Detection
    if (DialogLoopDetector(history)) {
        return NextResponse.json({ error: 'Dialog loop detected' }, { status: 400 });
    }

    // 5. Routing to Sovereign Hub (Placeholder for Hub RPC call)
    // Here we will eventually pipe to the Rust Hub CLI / API
    return NextResponse.json({ response: `Sovereign Hub acknowledged: ${prompt}` });
}
