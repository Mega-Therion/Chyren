#!/usr/bin/env python3
"""
omegactl — OmegA command-line interface.

Commands:
  audit     Run spec auditor
  eval      Run master evaluation suite
  map       Generate repo manifest
  build     Verify build
  run       Execute a prompt through the unified runtime
  ingest    Ingest a file into the document store
  caps      List registered capabilities
  providers List available providers
  reconcile Run memory reconciliation
"""
import json
import sys
import subprocess
from pathlib import Path

# Ensure repo root is on path
sys.path.insert(0, str(Path(__file__).parent))


def run_cmd(cmd):
    try:
        subprocess.run(cmd, check=True)
    except Exception as e:
        print(f"Error running {' '.join(cmd)}: {e}")


def cmd_run(args):
    """Execute a prompt through the RuntimeOrchestrator."""
    if not args:
        print("Usage: omegactl run \"<prompt>\" [--model MODEL] [--provider PROVIDER] [--json]")
        return

    prompt = args[0]
    model = ""
    provider = None
    output_json = False

    i = 1
    while i < len(args):
        if args[i] == "--model" and i + 1 < len(args):
            model = args[i + 1]
            i += 2
        elif args[i] == "--provider" and i + 1 < len(args):
            provider = args[i + 1]
            i += 2
        elif args[i] == "--json":
            output_json = True
            i += 1
        else:
            i += 1

    from omega.runtime import RuntimeOrchestrator
    rt = RuntimeOrchestrator()
    result = rt.run(task=prompt, model=model, provider=provider)

    if output_json:
        print(json.dumps(result.to_dict(), indent=2))
    else:
        trace = result.trace
        print(f"\n{'='*60}")
        print(f"  OmegA Runtime — run_id: {trace.run_id}")
        print(f"{'='*60}")
        print(f"  Provider : {trace.provider_name}")
        print(f"  Model    : {trace.model}")
        print(f"  Risk     : {trace.risk_score:.3f} ({'allowed' if trace.risk_allowed else 'BLOCKED'})")
        print(f"  Verify   : V={trace.verification_V:.3f} ({'pass' if trace.verification_passed else 'FAIL'})")
        print(f"  Mode     : {trace.answer_mode}")
        print(f"  Gate     : {'allowed' if trace.gate_allowed else 'BLOCKED'}")
        print(f"  Elapsed  : {trace.total_elapsed_ms:.0f}ms")
        print(f"  Stages   :")
        for s in trace.stages:
            print(f"    {s.stage.value:15s} {s.elapsed_ms:7.1f}ms  [{s.status}]")
        print(f"\n{'─'*60}")
        print(f"  Response:\n")
        print(f"  {result.text}")
        print(f"\n{'='*60}\n")


def cmd_ingest(args):
    """Ingest a file into the document store."""
    if not args:
        print("Usage: omegactl ingest <file_path> [--title TITLE]")
        return

    path = args[0]
    title = ""
    i = 1
    while i < len(args):
        if args[i] == "--title" and i + 1 < len(args):
            title = args[i + 1]
            i += 2
        else:
            i += 1

    from omega.docstore import DocumentStore
    from omega.ingest import IngestPlane

    store = DocumentStore()
    plane = IngestPlane(store, journal_path="data/ingest_journal")
    result = plane.ingest_file(path, title=title)

    if result.ok:
        print(f"[OK] Ingested: {result.doc_id}")
        print(f"  Hash    : {result.content_hash[:16]}...")
        print(f"  Version : {result.version}")
        print(f"  Status  : {result.status.value}")
        print(f"  Elapsed : {result.elapsed_ms:.0f}ms")
    else:
        print(f"[FAIL] {result.error}")


def cmd_caps(args):
    """List registered capabilities."""
    from omega.capabilities import CapabilityRegistry, default_capabilities
    reg = CapabilityRegistry()
    for cap in default_capabilities():
        reg.register(cap)

    output_json = "--json" in args
    if output_json:
        print(json.dumps(reg.to_dict(), indent=2))
    else:
        print(f"\n  Registered Capabilities ({reg.count}):")
        print(f"  {'─'*50}")
        for cap in reg.list_capabilities():
            human = " [HUMAN]" if cap.requires_human_approval else ""
            print(f"  {cap.id:30s}  {cap.risk_class.value:8s}  {cap.action_class.value:8s}{human}")
        print()


def cmd_providers(args):
    """List available providers."""
    from omega.providers.ollama import OllamaProvider
    from omega.providers.openai import OpenAIProvider
    from omega.providers.anthropic import AnthropicProvider
    from omega.providers.google import GoogleProvider

    providers = [OllamaProvider(), OpenAIProvider(), AnthropicProvider(), GoogleProvider()]
    print(f"\n  Provider Status:")
    print(f"  {'─'*40}")
    for p in providers:
        avail = p.is_available()
        status = "AVAILABLE" if avail else "unavailable"
        print(f"  {p.name:15s}  [{status}]")
    print()


def cmd_reconcile(args):
    """Run memory reconciliation."""
    from omega.memory import MemoryGraph
    from omega.docstore import DocumentStore
    from omega.reconcile import MemoryReconciler

    memory = MemoryGraph()
    docstore = DocumentStore()
    reconciler = MemoryReconciler(memory, docstore)
    report = reconciler.reconcile()

    output_json = "--json" in args
    if output_json:
        print(json.dumps(report.to_dict(), indent=2))
    else:
        print(f"\n  Reconciliation Report:")
        print(f"  {'─'*40}")
        print(f"  Duplicates  : {report.duplicates_found}")
        print(f"  Conflicts   : {report.conflicts_found}")
        print(f"  Stale       : {report.stale_found}")
        print(f"  Promotions  : {report.promotions}")
        print(f"  Demotions   : {report.demotions}")
        print(f"  Events      : {len(report.events)}")
        print(f"  Elapsed     : {report.elapsed_ms:.0f}ms")
        print()


def main():
    if len(sys.argv) < 2:
        print("Usage: omegactl <audit|eval|map|build|run|ingest|caps|providers|reconcile>")
        return

    cmd = sys.argv[1]
    rest = sys.argv[2:]

    if cmd == "audit":
        run_cmd(["python3", "tools/spec_auditor.py"])
    elif cmd == "eval":
        run_cmd(["python3", "tools/master_eval.py"])
    elif cmd == "map":
        run_cmd(["python3", "tools/repo_cartographer.py", "--output", "MANIFEST.md"])
    elif cmd == "build":
        run_cmd(["python3", "tools/obb.py", "verify", "--out", "verify.sh"])
    elif cmd == "run":
        cmd_run(rest)
    elif cmd == "ingest":
        cmd_ingest(rest)
    elif cmd == "caps":
        cmd_caps(rest)
    elif cmd == "providers":
        cmd_providers(rest)
    elif cmd == "reconcile":
        cmd_reconcile(rest)
    else:
        print(f"Unknown command: {cmd}")
        print("Available: audit, eval, map, build, run, ingest, caps, providers, reconcile")


if __name__ == "__main__":
    main()
