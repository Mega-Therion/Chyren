{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omega-architecture.dev/schemas/capability_manifest.schema.json",
  "title": "OmegA Capability Manifest",
  "description": "Schema for a declared executable capability in the AEGIS capability registry.",
  "type": "object",
  "required": [
    "id",
    "name",
    "action_class",
    "risk_class",
    "requires_human_approval",
    "allowed_contexts",
    "input_schema_ref",
    "output_schema_ref"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^cap\\.",
      "description": "Unique capability identifier (dot-separated namespace)"
    },
    "name": {
      "type": "string",
      "description": "Human-readable name"
    },
    "action_class": {
      "type": "string",
      "enum": ["read", "write", "execute", "delete", "network", "auth"]
    },
    "risk_class": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "requires_human_approval": {
      "type": "boolean"
    },
    "allowed_contexts": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "input_schema_ref": {
      "type": "string",
      "description": "Path or URI to the input contract schema"
    },
    "output_schema_ref": {
      "type": "string",
      "description": "Path or URI to the output contract schema"
    },
    "description": {
      "type": "string",
      "default": ""
    },
    "registered_at": {
      "type": "number",
      "description": "Unix timestamp of registration"
    }
  },
  "additionalProperties": false
}
