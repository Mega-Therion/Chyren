async def repl(resume_id: Optional[str] = None):
    session: PromptSession = PromptSession(
        history=FileHistory(str(READLINE_HISTORY)),
        auto_suggest=AutoSuggestFromHistory(),
        style=PROMPT_STYLE,
        key_bindings=make_bindings(),
        enable_history_search=True,
        mouse_support=False,
    )

    session_id = resume_id or new_session_id()
    history: list = []
    state: dict   = {"created_at": datetime.now().isoformat()}

    # Resume if requested
    if resume_id:
        data = load_session(resume_id)
        if data:
            history = data.get("messages", [])
            state   = data.get("state", state)
            state["created_at"] = data.get("created_at", state["created_at"])

    pending_context = ""   # injected by /read or /search
    save_counter    = 0

    print_banner(session_id)

    while True:
        try:
            line = await session.prompt_async(
                HTML("<prompt>you</prompt> <prompt.arrow>вҖә</prompt.arrow> ")
            )
        except (EOFError, KeyboardInterrupt):
            save_session(session_id, history, state)
            console.print(f"\n[muted]  session saved вҶ’ {session_id}[/muted]\n")
            return

        line = line.strip()
        if not line:
            continue

        # в”Җв”Җ Bang commands в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
        if line.startswith("!"):
            await run_shell_command(line[1:].strip())
            continue

        # в”Җв”Җ Slash commands в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
        parts = line.split(None, 1)
        cmd   = parts[0].lower()
        args  = parts[1] if len(parts) > 1 else ""

        if cmd in ("/exit", "/quit", "exit", "quit"):
            save_session(session_id, history, state)
            console.print(f"\n[muted]  session saved вҶ’ {session_id}[/muted]\n")
            return

        if cmd == "/new":
            save_session(session_id, history, state)
            history.clear()
            pending_context = ""
            session_id = new_session_id()
            state = {"created_at": datetime.now().isoformat()}
            console.print(f"\n[muted]  new session:[/muted] [dim]{session_id}[/dim]\n")
            continue

        if cmd == "/help":
            await cmd_help()
            continue

        if cmd == "/state":
            await cmd_state()
            continue

        if cmd == "/chain":
            await cmd_chain()
            continue

        if cmd == "/sessions":
            await cmd_sessions()
            continue

        if cmd == "/resume":
            session_id, history, state = await cmd_resume(
                args, session_id, history, state
            )
            continue

        if cmd == "/save":
            save_session(session_id, history, state)
            console.print(f"\n[green]  вң“ saved:[/green] [dim]{session_id}[/dim]\n")
            continue

        if cmd == "/read":
            pending_context = await cmd_read(args)
            if pending_context:
                console.print(
                    "  [muted]file loaded вҖ” it will be injected into your next message[/muted]\n"
                )
            continue

        if cmd == "/search":
            pending_context = await cmd_search(args)
            if pending_context:
                console.print(
                    "  [muted]results loaded вҖ” injecting into your next message[/muted]\n"
                )
            continue

        if cmd == "/files":
            await cmd_files(args)
            continue

        if cmd == "/dashboard":
            await cmd_dashboard(session_id, history)
            continue

        if cmd in ("/history", "/log"):
            await cmd_history_show(history)
            continue

        # в”Җв”Җ /monitor command в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
        if cmd.startswith("/monitor"):
            if monitoring:
                console.print("\n[cyan]Starting real-time monitoring (Ctrl+C to stop)...[/cyan]\n")
                db1_url = os.environ.get("OMEGA_DB_URL", "")
                db2_url = os.environ.get("OMEGA_DB2_URL", "")
                try:
                    monitoring.monitor_live(db1_url, db2_url, API_BASE, interval=10)
                except Exception as e:
                    console.print(f"\n[red]Error during monitoring: {e}[/red]\n")
                # Log to ERGON
                if audit:
                    audit.log_cli_action("/monitor", exit_code=0, duration_sec=0)
            else:
                console.print("\n[red]Monitoring module not available[/red]\n")
            continue

        # в”Җв”Җ /help command в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
        if cmd in ("/help", "/h", "/?"):
            console.print("\n[cyan]Available commands:[/cyan]")
            console.print("  /monitor              Show real-time DB and API status")
            console.print("  /new                  Start a new session")
            console.print("  /sessions             List saved sessions")
            console.print("  /state                Show last response state")
            console.print("  !cmd                  Run shell command")
            console.print("  Ctrl+C                Exit\n")
            continue

        # в”Җв”Җ Unknown slash command в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
        if cmd.startswith("/"):
            console.print(f"\n[muted]  unknown command: {cmd}  (try /help)[/muted]\n")
            continue

        # в”Җв”Җ Send to OmegA в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
        inject  = pending_context
        pending_context = ""

        reply = await stream_response(line, history, inject_context=inject)

        if reply:
            history.append({"role": "user",  "text": line})
            history.append({"role": "omega", "text": reply})
            state["provider"] = last_state.get("provider", "?")

            # Auto-save every 10 turns
            save_counter += 1
            if save_counter % 10 == 0:
                save_session(session_id, history, state)

